# ==============================================================================
# EnvAudit - Environment Variables Template
# Copy this file and rename it to exactly `.env` for local testing.
# ==============================================================================

# ── LLM Inference Settings (Required for inference.py) ──────────

# Your Hugging Face User Access Token (Requires 'Inference' permissions)
HF_TOKEN=hf_your_token_here

# The API endpoint for the LLM (Default: Hugging Face Serverless API)
API_BASE_URL=https://router.huggingface.co/v1

# The model identifier to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ── Environment Server Settings (Optional / Defaults) ───────────

# URL where the EnvAudit FastAPI server is running locally
AUDIT_ENV_URL=http://localhost:7860

# Docker image name (if testing the validator script locally)
LOCAL_IMAGE_NAME=saas-audit-env